rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper functions use `resource.data.get(key, default)` for every optional
    // field. Firestore 'list' rule evaluation is strict on undefined field
    // access and throws PERMISSION_DENIED instead of treating missing fields as
    // null (production error: "Property visibility is undefined on object.
    // for 'list' @ L32"). Defaults match RegistryDto defaults so new-doc
    // semantics are unchanged; legacy docs predating the visibility /
    // invitedUsers fields (Phase 03) are handled via the defaults.
    function isOwner(registryData) {
      // Empty-string default fails closed — no client has auth.uid == '' so a
      // doc missing ownerId is unreadable/unwritable by every caller.
      return isSignedIn() && request.auth.uid == registryData.get('ownerId', '');
    }

    function isPublicRegistry(registryData) {
      // Legacy docs predate `visibility` (added in Phase 03). Default to
      // 'public' to match RegistryDto.visibility = "public" — avoids the
      // PERMISSION_DENIED throw on undefined field access in list evaluation.
      return registryData.get('visibility', 'public') == 'public';
    }

    function isInvited(registryData) {
      // Defensive .get() for both fields. Legacy docs predate `invitedUsers`;
      // empty-map default means no one is invited, which is safe.
      return isSignedIn() &&
             registryData.get('visibility', 'public') == 'private' &&
             registryData.get('invitedUsers', {})[request.auth.uid] == true;
    }

    function canReadRegistry(registryData) {
      // isOwner first: belt-and-suspenders defense. For owner-filtered list
      // queries (whereEqualTo('ownerId', uid)) isOwner short-circuits true
      // and the visibility/invitedUsers checks are skipped entirely — no
      // field-access path can throw on legacy docs even if .get() were wrong.
      return isOwner(registryData) ||
             isPublicRegistry(registryData) ||
             isInvited(registryData);
    }

    // Registries collection
    match /registries/{registryId} {
      allow read: if canReadRegistry(resource.data);
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data);

      // Items subcollection — inherits registry visibility for reads
      match /items/{itemId} {
        allow read: if canReadRegistry(
          get(/databases/$(database)/documents/registries/$(registryId)).data
        );
        allow create, update, delete: if isOwner(
          get(/databases/$(database)/documents/registries/$(registryId)).data
        );
      }

      // Invites subcollection — owner-only read/write
      match /invites/{inviteId} {
        allow read, write: if isOwner(
          get(/databases/$(database)/documents/registries/$(registryId)).data
        );
      }
    }

    // Phase 4 (RES-09 / D-19): Reservations are ONLY writable by Cloud Functions
    // via Admin SDK (which bypasses rules). All client writes are denied.
    // createReservation callable runs a runTransaction to guarantee atomicity.
    match /reservations/{reservationId} {
      allow read, write: if false;
    }

    // Users — owner reads/writes their own document only
    match /users/{userId} {
      allow read, update: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // Phase 6: mail collection — Trigger Email extension manages via Admin SDK.
    // No client read or write is allowed.
    match /mail/{docId} {
      allow read, write: if false;
    }

    // Phase 6: notifications_failures — ops-only log (Admin SDK bypasses rules).
    match /notifications_failures/{docId} {
      allow read, write: if false;
    }

    // Phase 6: FCM tokens subcollection — each user owns their own tokens.
    // Another user cannot enumerate or read another user's tokens.
    match /users/{userId}/fcmTokens/{tokenId} {
      allow read, write, delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Phase 7 (STORE-01 / D-21): config collection — world-readable so the
    // Store Browser can load the store list even for unauthenticated
    // onboarding states. No client writes — admin only via seed script
    // (Admin SDK bypasses rules).
    match /config/{configId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
