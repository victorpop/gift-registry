# Firebase
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
firestore-debug.*.log
ui-debug.log
.firebase/

# Functions
functions/lib/
functions/node_modules/

# Rules test harness
tests/rules/node_modules/

# Hosting
# hosting/public/ is the Vite build output root (written by `cd web && npm run build`)
# All contents are generated; source of truth lives in web/src/ and web/public/
hosting/public/assets/
hosting/public/index.html
hosting/public/vite.svg
hosting/public/.well-known/

# Web node_modules and build artifacts
web/node_modules/
web/package-lock.json
web/tsconfig.*.tsbuildinfo

# Environment
.env
.env.local

# Firebase Extensions secrets — the extension CLI writes SMTP keys etc. to
# .secret.local files per extension instance. Never commit these.
extensions/*.secret.local
*.secret.local

# IDE
.idea/
*.iml
.DS_Store

# Android (Phase 2+)
*.apk
*.aab
.gradle/
.kotlin/
build/
local.properties
# Firebase Android config — each dev downloads from Firebase Console and registers
# their own debug SHA-1 (keeps per-machine OAuth client entries out of git)
app/google-services.json

# Claude local workspace (per-user; not shared)
.claude/
