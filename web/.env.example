# Firebase config — public values (safe to commit examples; real values in .env.local)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# reCAPTCHA v3 site key from Firebase Console > App Check (production only)
VITE_RECAPTCHA_SITE_KEY=

# App Check debug token (dev only) — generated on first run, register in Firebase Console
VITE_APP_CHECK_DEBUG_TOKEN=

# Emulator switch — set to "true" to use local emulators on Auth=9099 Functions=5001 Firestore=8080
VITE_USE_EMULATORS=false
